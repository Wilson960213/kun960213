{
  "manifest_version": 3,
  "name": "FocusPaw",
  "version": "1.0",
  "description": "你的桌面猫咪陪伴专注助手",
  "permissions": ["storage", "tabs", "activeTab", "scripting", "alarms", "notifications"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["css/cat.css"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/cat/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "FocusPaw"
  }
}